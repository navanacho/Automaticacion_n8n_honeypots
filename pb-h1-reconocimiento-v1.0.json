{
  "name": "PB-H1 - Reconocimiento y Escaneo (T1595/T1046)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "cowrie",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-cowrie",
      "name": "Webhook Cowrie",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "cowrie-webhook-001"
    },
    {
      "parameters": {
        "functionCode": "// Normalizar datos del honeypot\nconst event = $input.all()[0].json;\n\nreturn {\n  timestamp: event.timestamp || new Date().toISOString(),\n  source_honeypot: 'cowrie',\n  src_ip: event.src_ip || event.source_ip,\n  dst_port: event.dst_port || event.port,\n  session_id: event.session || event.session_id,\n  commands: event.input || event.command || '',\n  event_type: event.event || 'connection',\n  playbook_id: 'PB-H1-v1.0',\n  att_ck_technique: event.dst_port === 2222 ? 'T1595' : 'T1046'\n};"
      },
      "id": "function-normalize",
      "name": "Normalizar Datos",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.abuseipdb.com/api/v2/check",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "ipAddress",
              "value": "={{ $json[\"src_ip\"] }}"
            },
            {
              "name": "maxAgeInDays",
              "value": "90"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Key",
              "value": "={{ $credentials[\"AbuseIPDB_API\"][\"apiKey\"] }}"
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "options": {}
      },
      "id": "http-abuseipdb",
      "name": "AbuseIPDB Lookup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [650, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "abuseipdb-cred-001",
          "name": "AbuseIPDB_API"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.shodan.io/shodan/host/{{ $json[\"src_ip\"] }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "key",
              "value": "={{ $credentials[\"Shodan_API\"][\"apiKey\"] }}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-shodan",
      "name": "Shodan Lookup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [850, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "shodan-cred-001",
          "name": "Shodan_API"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// Calcular score de riesgo\nconst abuseData = $input.all()[1].json.data || {};\nconst shodanData = $input.all()[2].json || {};\n\nlet score = 0;\n\n// Score por reputación AbuseIPDB\nconst abuseScore = abuseData.abuseConfidenceScore || 0;\nif (abuseScore > 50) score += 0.3;\nif (abuseScore > 80) score += 0.2;\n\n// Score por tipo de organización (hosting/cloud = más riesgoso)\nconst org = shodanData.org || '';\nif (org.toLowerCase().includes('hosting') || org.toLowerCase().includes('cloud')) {\n  score += 0.2;\n}\n\n// Score por múltiples puertos escaneados\nconst openPorts = shodanData.ports || [];\nif (openPorts.length > 5) score += 0.2;\n\n// Score por vulnerabilidades conocidas\nconst vulns = shodanData.vulns || [];\nif (vulns.length > 0) score += 0.2;\n\n// Normalizar score entre 0 y 1\nscore = Math.min(score, 1.0);\n\nreturn {\n  ...$input.all()[0].json,\n  risk_score: score,\n  abuse_confidence: abuseScore,\n  organization: org,\n  open_ports_count: openPorts.length,\n  has_vulns: vulns.length > 0,\n  enrichment_timestamp: new Date().toISOString()\n};"
      },
      "id": "function-scoring",
      "name": "Calcular Risk Score",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json[\"risk_score\"] }}",
              "operation": "greaterEqual",
              "value2": "0.8"
            }
          ]
        }
      },
      "id": "switch-high-risk",
      "name": "¿Riesgo Alto? (≥0.8)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json[\"risk_score\"] }}",
              "operation": "greaterEqual",
              "value2": "0.5"
            },
            {
              "value1": "={{ $json[\"risk_score\"] }}",
              "operation": "smaller",
              "value2": "0.8"
            }
          ]
        }
      },
      "id": "switch-medium-risk",
