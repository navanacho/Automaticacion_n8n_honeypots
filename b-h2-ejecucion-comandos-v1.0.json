{
  "name": "PB-H2 - Ejecución de Comandos Maliciosos (T1059)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "cowrie-command",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-command",
      "name": "Webhook Comandos",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "cowrie-command-webhook-001"
    },
    {
      "parameters": {
        "functionCode": "// Extraer IOCs de comandos\nconst event = $input.all()[0].json;\nconst command = event.input || event.command || '';\n\n// Extraer URLs con regex\nconst urlRegex = /(https?:\\/\\/[^\\s]+)/g;\nconst urls = command.match(urlRegex) || [];\n\n// Extraer dominios\nconst domainRegex = /(?:https?:\\/\\/)?([\\w\\-]+\\.[\\w\\-\\.]+)/g;\nconst domains = command.match(domainRegex) || [];\n\n// Detectar comandos peligrosos\nconst dangerousCommands = ['rm -rf', 'chmod 777', 'nc -e', 'wget', 'curl', 'python -c', 'bash -i'];\nconst isDangerous = dangerousCommands.some(dc => command.toLowerCase().includes(dc));\n\nreturn {\n  timestamp: event.timestamp || new Date().toISOString(),\n  source_honeypot: 'cowrie',\n  src_ip: event.src_ip || event.source_ip,\n  session_id: event.session || event.session_id,\n  commands: command,\n  extracted_urls: urls,\n  extracted_domains: domains,\n  is_dangerous_command: isDangerous,\n  playbook_id: 'PB-H2-v1.0',\n  att_ck_technique: 'T1059'\n};"
      },
      "id": "function-extract-iocs",
      "name": "Extraer IOCs",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://www.virustotal.com/api/v3/files/{{ $json[\"file_hash\"] }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-apikey",
              "value": "={{ $credentials[\"VirusTotal_API\"][\"apiKey\"] }}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-virustotal",
      "name": "VirusTotal Lookup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [650, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "virustotal-cred-001",
          "name": "VirusTotal_API"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.whoisfreaks.com/v1.0/whois",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "domainName",
              "value": "={{ $json[\"extracted_domains\"][0] }}"
            },
            {
              "name": "apiKey",
              "value": "={{ $credentials[\"Whois_API\"][\"apiKey\"] }}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-whois",
      "name": "WHOIS Domain",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [850, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "whois-cred-001",
          "name": "Whois_API"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// Calcular score de riesgo para comandos\nconst vtData = $input.all()[1].json.data || {};\nconst whoisData = $input.all()[2].json || {};\nconst event = $input.all()[0].json;\n\nlet score = 0;\n\n// Score por detecciones en VirusTotal\nconst vtDetections = vtData.attributes?.last_analysis_stats?.malicious || 0;\nif (vtDetections > 5) score += 0.4;\nif (vtDetections > 10) score += 0.2;\n\n// Score por dominio reciente (< 30 días)\nconst domainAge = whoisData.created_date || '';\nif (domainAge) {\n  const created = new Date(domainAge);\n  const daysOld = (new Date() - created) / (1000 * 60 * 60 * 24);\n  if (daysOld < 30) score += 0.3;\n}\n\n// Score por comando peligroso\nif (event.is_dangerous_command) score += 0.3;\n\n// Score por múltiples URLs\nif (event.extracted_urls.length > 2) score += 0.2;\n\nscore = Math.min(score, 1.0);\n\nreturn {\n  ...event,\n  risk_score: score,\n  vt_detections: vtDetections,\n  domain_age_days: domainAge ? ((new Date() - new Date(domainAge)) / (1000 * 60 * 60 * 24)).toFixed(0) : 'N/A',\n  enrichment_timestamp: new Date().toISOString()\n};"
      },
      "id": "function-scoring-h2",
      "name": "Calcular Risk Score",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json[\"risk_score\"] }}",
              "operation": "greaterEqual",
              "value2": "0.75"
            }
          ]
        }
      },
      "id": "switch-critical",
      "name": "¿Riesgo Crítico? (≥0.75)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1250, 300]
    },
